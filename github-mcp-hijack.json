      "block": true
    },
    "npm_publish": {
      "block": true
    },
    "send_email": {
      "block": true
    },
    "send_message": {
      "block": true
    },
    "upload_file": {
      "require_approval": true,
      "min_tier": "signed-known"
    },
    "http_request": {
      "require_approval": true,
      "rate_limit": "5/minute"
    },
    "webhook": {
      "block": true
    },
    "read_file": {
      "rate_limit": "30/minute"
    },
    "search_code": {
      "rate_limit": "20/minute"
    }
  },
  "signing": {
    "enabled": true
  }
}
